<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — FarmLink</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌾</text></svg>">
</head>
<body data-page="dashboard">
<div id="navbarMount"></div>

<div class="app-layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div style="padding:12px;margin-bottom:8px;background:var(--primary-pale);border-radius:var(--radius-lg);text-align:center">
      <div style="font-size:2.5rem;margin-bottom:4px">👤</div>
      <div style="font-weight:700;font-size:.95rem" id="userName"></div>
      <div style="font-size:.78rem;color:var(--text-muted)" id="userRole"></div>
      <span class="badge badge-green mt-2" id="userRoleBadge"></span>
    </div>
    <div class="sidebar-title">Navigation</div>
    <div class="sidebar-link active"><span class="icon">🏠</span> Dashboard</div>
    <a href="/marketplace.html" class="sidebar-link"><span class="icon">🛒</span> Marketplace</a>
    <a href="/cart.html" class="sidebar-link"><span class="icon">🛍️</span> My Cart</a>
    <a href="/orders.html" class="sidebar-link"><span class="icon">📋</span> My Orders</a>
    <div class="sidebar-title" style="margin-top:12px">Account</div>
    <div class="sidebar-link" onclick="handleLogout()"><span class="icon">🚪</span> Logout</div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <!-- FARMER SECTION -->
    <div id="farmerSection" class="hidden">
      <div class="page-header">
        <div>
          <h1>Farmer Dashboard 🧑‍🌾</h1>
          <div class="page-subtitle">Manage your products and track sales</div>
        </div>
        <span class="badge badge-green" id="farmerProductCount">0 Products</span>
      </div>

      <!-- Quick Stats -->
      <div class="grid-4 mb-6">
        <div class="stat-card">
          <div class="stat-icon green">📦</div>
          <div><div class="stat-value">12</div><div class="stat-label">Products Listed</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon orange">🛒</div>
          <div><div class="stat-value">87</div><div class="stat-label">Orders Received</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue">💰</div>
          <div><div class="stat-value">₹48,250</div><div class="stat-label">Total Revenue</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple">⭐</div>
          <div><div class="stat-value">4.8</div><div class="stat-label">Avg. Rating</div></div>
        </div>
      </div>

      <!-- Add Product Form -->
      <div class="card mb-6">
        <div class="section-title">➕ Add New Product</div>
        <form id="farmerProductForm">
          <div class="form-row mb-4">
            <div class="form-group">
              <label class="form-label">Product Name *</label>
              <input type="text" id="pName" class="form-control" placeholder="e.g. Organic Basmati Rice" required>
            </div>
            <div class="form-group">
              <label class="form-label">Category *</label>
              <select id="pCategory" class="form-control" required>
                <option value="">Select category</option>
                <option value="Grains">Grains</option>
                <option value="Vegetables">Vegetables</option>
                <option value="Fruits">Fruits</option>
                <option value="Spices">Spices</option>
                <option value="Dairy &amp; Honey">Dairy &amp; Honey</option>
                <option value="Oils">Oils</option>
                <option value="Pulses">Pulses</option>
              </select>
            </div>
          </div>
          <div class="form-row mb-4">
            <div class="form-group">
              <label class="form-label">Price (₹) *</label>
              <input type="number" id="pPrice" class="form-control" placeholder="Price per unit" min="1" required>
            </div>
            <div class="form-group">
              <label class="form-label">Quantity Available *</label>
              <input type="number" id="pQty" class="form-control" placeholder="e.g. 200 kg" min="1" required>
            </div>
          </div>
          <div class="form-group mb-4">
            <label class="form-label">Product Image URL</label>
            <input type="url" id="pImage" class="form-control" placeholder="https://image-url.com/product.jpg">
          </div>
          <div class="form-group mb-4">
            <label class="form-label">Description</label>
            <textarea id="pDesc" class="form-control" rows="3" placeholder="Describe your product — freshness, origin, quality..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">🌾 List Product</button>
        </form>
      </div>

      <!-- Farmer's Products -->
      <div class="section-title">My Products</div>
      <div class="grid-auto" id="farmerProductsGrid"></div>
    </div>

    <!-- BUYER SECTION -->
    <div id="buyerSection" class="hidden">
      <div class="page-header">
        <div>
          <h1>Welcome Back! 👋</h1>
          <div class="page-subtitle">Discover fresh products from farmers near you</div>
        </div>
        <a href="/marketplace.html" class="btn btn-primary">Browse All →</a>
      </div>

      <!-- Buyer Stats -->
      <div class="grid-4 mb-6">
        <div class="stat-card">
          <div class="stat-icon orange">🛒</div>
          <div><div class="stat-value">3</div><div class="stat-label">Active Orders</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green">✅</div>
          <div><div class="stat-value">18</div><div class="stat-label">Completed Orders</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue">💰</div>
          <div><div class="stat-value">₹12,450</div><div class="stat-label">Total Spent</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple">⭐</div>
          <div><div class="stat-value">7</div><div class="stat-label">Reviews Given</div></div>
        </div>
      </div>

      <!-- Search -->
      <div class="search-bar mb-6" style="margin-bottom:20px">
        <div class="search-input-wrap">
          <span class="search-icon">🔍</span>
          <input type="text" id="buyerSearch" class="search-input" placeholder="Search products, farmers...">
        </div>
        <select id="buyerCategory" class="filter-select">
          <option value="All">All Categories</option>
          <option>Grains</option><option>Vegetables</option><option>Fruits</option>
          <option>Spices</option><option>Dairy &amp; Honey</option><option>Oils</option>
        </select>
        <a href="/marketplace.html" class="btn btn-secondary btn-sm">Full Marketplace →</a>
      </div>

      <div class="section-title">Featured Products</div>
      <div class="grid-auto" id="buyerProductsGrid"></div>
    </div>
  </main>
</div>

<!-- Edit Product Modal -->
<div class="modal-overlay hidden" id="editModal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modalProductName">Edit Product</div>
      <button class="modal-close" onclick="closeEditModal()">✕</button>
    </div>
    <form onsubmit="handleEditProduct(event)">
      <input type="hidden" id="editProductId">
      <div class="form-group mb-4">
        <label class="form-label">Product Name</label>
        <input type="text" id="editPName" class="form-control" required>
      </div>
      <div class="form-row mb-4">
        <div class="form-group">
          <label class="form-label">Price (₹)</label>
          <input type="number" id="editPPrice" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">Quantity</label>
          <input type="number" id="editPQty" class="form-control" required>
        </div>
      </div>
      <div style="display:flex;gap:12px">
        <button type="button" class="btn btn-ghost flex-1" onclick="closeEditModal()">Cancel</button>
        <button type="submit" class="btn btn-primary flex-1">✅ Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/api.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
